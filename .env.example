# Vite only exposes env vars prefixed with VITE_ to client-side code

# Required — used by PlotBoundaryTracer.jsx (satellite map + click-to-draw polygon)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Only needed if the backend is deployed at a different address than the
# frontend (e.g. frontend on S3/CloudFront, backend on EC2 — a common AWS
# split). Leave blank for local dev — Vite's proxy handles it instead.
VITE_API_BASE_URL=
